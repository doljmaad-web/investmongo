# Gemini API (FREE — get key from aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here

# Hyperliquid (agent wallet — NOT your main wallet private key)
HL_PRIVATE_KEY=0x_your_agent_wallet_private_key
HL_WALLET_ADDRESS=0x_your_main_wallet_address
HL_TESTNET=true

# Telegram bot (get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Server config
PORT=3000
WEBHOOK_SECRET=investmongo_webhook_2024
BOT_SERVER_URL=https://your-app.up.railway.app

# Paper trading starting balance (USD)
PAPER_BALANCE=10000

# Finnhub API (FREE tier — get key from finnhub.io)
# Enables macro event calendar (FOMC, CPI, etc.) for Gemini risk assessment
FINNHUB_API_KEY=your_finnhub_api_key
